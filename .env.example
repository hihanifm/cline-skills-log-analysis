# Android Log & PCAP Analysis — LLM Backend Configuration
#
# Copy this file to .env and fill in your values.
# The synthesizer agent searches for .env starting from the workflow
# scripts directory, walking up to the project root and home directory.

# ── LLM Backend ───────────────────────────────────────────────────────────────
#
# anthropic  → call Anthropic API directly (requires ANTHROPIC_API_KEY below)
# cline      → write <!-- SUMMARY_PROMPT --> markers for Cline to fill in
#
# Default: cline (used when this file is absent or LLM_BACKEND is not set)
LLM_BACKEND=cline

# ── Anthropic API Key ─────────────────────────────────────────────────────────
#
# Required only when LLM_BACKEND=anthropic.
# Get your key at: https://console.anthropic.com/
#
# ANTHROPIC_API_KEY=sk-ant-...

# ── Workflow Output Directory ─────────────────────────────────────────────────
#
# Base directory for all workflow outputs.
# Each workflow's `output.dir` frontmatter is treated as a relative subdirectory
# under this path. If unset, outputs are written relative to the input file
# directory (backwards-compatible behavior).
#
# Example (recommended default):
#   WORKFLOW_OUTPUT_DIR=$HOME/analysis-outputs
#
WORKFLOW_OUTPUT_DIR=$HOME/analysis-outputs
